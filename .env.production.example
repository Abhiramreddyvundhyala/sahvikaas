# Production Environment Variables
# Copy this file to .env.production and update with your actual backend URL

# Backend API URL (from Render, Railway, or your deployment service)
VITE_API_URL=https://your-backend-url.onrender.com

# Example URLs:
# Render: https://studyhub-backend-xxxx.onrender.com
# Railway: https://studyhub-backend-production.up.railway.app
# Heroku: https://studyhub-backend.herokuapp.com
